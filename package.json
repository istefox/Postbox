{
  "name": "maildrop",
  "version": "0.1.0",
  "description": "Obsidian plugin that imports .eml and .msg email files and converts them into native Markdown notes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "email",
    "eml",
    "msg",
    "markdown"
  ],
  "author": "Stefano Ferri",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/turndown": "^5.0.4",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.25.0",
    "obsidian": "^1.5.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@kenjiuno/msgreader": "^1.22.0",
    "postal-mime": "^2.2.0",
    "turndown": "^7.1.2",
    "turndown-plugin-gfm": "^1.0.2"
  }
}
